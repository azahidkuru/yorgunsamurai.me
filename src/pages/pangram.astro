---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Pangram Oluşturucu">
  <main>
    <h1>Pangram Oluşturucu</h1>
    <<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>Pangram İstasyonu</title>
    <style>
        body { background: #1a1a1a; color: #e0e0e0; font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .container { width: 90%; max-width: 600px; text-align: center; }
        .alphabet { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-bottom: 30px; }
        .letter { width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; border-radius: 4px; border: 1px solid #444; font-weight: bold; background: #333; color: #fff; box-shadow: 0 0 10px rgba(255,255,255,0.2); transition: all 0.3s ease; }
        .letter.off { background: #111; color: #444; border-color: #222; box-shadow: none; text-shadow: none; opacity: 0.3; }
        textarea { width: 100%; height: 100px; background: #222; color: #fff; border: 2px solid #444; border-radius: 8px; padding: 15px; font-size: 18px; outline: none; resize: none; transition: border-color 0.3s; }
        textarea:focus { border-color: #007bff; }
        .stats { margin-top: 15px; font-size: 14px; color: #888; }
    </style>
</head>
<body>

<div class="container">
    <div class="alphabet" id="alphabet"></div>
    <textarea id="input" placeholder="Pangramınızı yazmaya başlayın..."></textarea>
    <div class="stats" id="stats">Kalan harf: 29</div>
</div>

<script>
    const letters = "ABCÇDEFGĞHIİJKLMNOÖPRSŞTUÜVYZ".split("");
    const alphabetDiv = document.getElementById('alphabet');
    const input = document.getElementById('input');
    const stats = document.getElementById('stats');

    // Alfabeyi oluştur
    letters.forEach(char => {
        const span = document.createElement('span');
        span.textContent = char;
        span.className = 'letter';
        span.id = 'L-' + char;
        alphabetDiv.appendChild(span);
    });

    input.addEventListener('input', () => {
        const text = input.value.toUpperCase();
        let foundCount = 0;

        letters.forEach(char => {
            const el = document.getElementById('L-' + char);
            if (text.includes(char)) {
                el.classList.add('off');
                foundCount++;
            } else {
                el.classList.remove('off');
            }
        });

        stats.textContent = `Kalan harf: ${29 - foundCount}`;
        
        if (foundCount === 29) {
            stats.innerHTML = "<b style='color: #4caf50;'>Tebrikler! Mükemmel bir pangram.</b>";
        }
    });
</script>

</body>
</html>
  </main>
</Layout>
