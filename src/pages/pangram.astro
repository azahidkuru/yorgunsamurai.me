---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Pangram Oluşturucu | Yorgun Samuray">
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 pb-12">
    <section class="mt-8">
      <h1 class="text-2xl font-semibold sm:text-3xl">Pangram Oluşturucu</h1>
      <p class="mt-2 italic">Alfabenin tüm harflerini içeren o kusursuz cümleyi ara.</p>
      
      <div class="mt-8 space-y-4">
        <textarea 
          id="pangram-input" 
          class="w-full rounded border border-skin-line bg-skin-fill p-4 focus:outline-none" 
          rows="5" 
          placeholder="Cümlenizi buraya yazın..."></textarea>
        
        <div id="result" class="rounded bg-skin-card p-4 text-sm shadow-sm">
          Harf kullanımını kontrol etmek için yazmaya başlayın.
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const input = document.querySelector('#pangram-input');
  const result = document.querySelector('#result');
  const alphabet = "abcçdefgğhıijklmnoöprsştuüvyz".split("");

  input?.addEventListener('input', (e) => {
    const text = e.target.value.toLowerCase();
    const missing = alphabet.filter(char => !text.includes(char));
    
    if (text.length === 0) {
      result.innerHTML = "Harf kullanımını kontrol etmek için yazmaya başlayın.";
    } else if (missing.length === 0) {
      result.innerHTML = "<span style='color: #4ade80;'>Tebrikler! Bu bir pangram.</span>";
    } else {
      result.innerHTML = `Eksik harfler: <b style='letter-spacing: 2px;'>${missing.join(" ").toUpperCase()}</b>`;
    }
  });
</script>
